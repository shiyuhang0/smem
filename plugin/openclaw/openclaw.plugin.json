{
  "id": "smem-openclaw",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "serverURL": {
        "type": "string"
      },
      "toolMode": {
        "type": "boolean"
      },
      "topK": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10
      },
      "storeMode": {
        "type": "string",
        "enum": ["normal", "smart"]
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 120000
      }
    }
  },
  "uiHints": {
    "serverURL": {
      "label": "Server URL",
      "placeholder": "http://localhost:8080"
    },
    "toolMode": {
      "label": "Tool Mode",
      "help": "Enabled uses memory_search and memory_store as the default path. Disabled switches to hook-based automatic recall and store each turn."
    },
    "topK": {
      "label": "Recall Top K"
    },
    "storeMode": {
      "label": "Store Mode"
    },
    "timeoutMs": {
      "label": "Timeout (ms)",
      "advanced": true
    }
  }
}
